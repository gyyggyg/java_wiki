# ============================================
# Java Wiki 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# ============================================
# 【必需】Neo4j 图数据库连接
# ============================================
# 两种命名均支持：run_all.py 会自动把 WIKI_NEO4J_* 透传给
# Api_and_Rabbitmq/ 下的脚本期望的 NEO4J_*
WIKI_NEO4J_URI=bolt://localhost:7689
WIKI_NEO4J_USER=neo4j
WIKI_NEO4J_PASSWORD=your_password


# ============================================
# 【必需】LLM API 配置
# ============================================
# OpenAI 或 OpenAI 兼容网关（如自建 reverse proxy、DeepSeek、Azure OpenAI 等）
# BASE_URL 结尾的斜杠会被自动剥离，写或不写都可以
BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here

# LLM 模型（所有脚本统一从这里读取）
# 常见选项：gpt-5-mini / gpt-4.1 / gpt-4o-mini / deepseek-chat
LLM_MODEL=gpt-5-mini
LLM_PROVIDER=openai


# ============================================
# 【可选】Java 项目配置
# ============================================
# Java 项目的 pom.xml 绝对路径（模块取名步骤使用）
POM_PATHS=/path/to/your/java/project/pom.xml

# Neo4j 图中文件路径的根目录前缀（API 文档 / 后端集成清单 / RabbitMQ 分析使用，
# 用于拼接完整相对路径）
ROOT_PREFIX=mall


# ============================================
# 【可选】并发与超时控制
# ============================================
# 单次 Block 文档生成 workflow 的最大并发数
# 根据 LLM API 速率限制调整：
#   - GPT-4 Tier1（500 RPM）：建议 10-20
#   - GPT-4 Tier2（5000 RPM）：建议 50-100
MAX_CONCURRENT_BLOCKS=10

# generate_api_docs.py 单次 LLM 调用超时（秒）
# 处理大型项目 Controller 分组时，30 秒常不够，建议 >=120
LLM_TIMEOUT=120

# LLMInterface chain 级别的 transient error 重试次数
# 对应本地网关偶发的"流式传输中断"等可恢复错误
LLM_CHAIN_MAX_RETRIES=4


# ============================================
# 【可选】Root 扩展章节 + Block 级可选章节（步骤 2 / 步骤 8）
# 需要本地安装 Claude Code CLI，且 which claude 能找到
# ============================================
# Java 源码根目录的绝对路径
# 同时被以下两处使用：
#   - step2_root_doc：Claude CLI 生成 tech_stack / layered_architecture 等扩展章节
#   - step8_optional_sections：Claude CLI 生成状态机 / 消息队列等 Block 级可选章节（--run-optional）
# SOURCE_ROOT_PATH=/path/to/java/source/root

# Claude CLI 使用的模型，默认 sonnet；可选 opus / haiku
# CLAUDE_MODEL=sonnet

# Claude CLI 单次调用超时（秒）
# AGENT_TIMEOUT=600

# Claude CLI 调用失败重试次数
# AGENT_MAX_RETRIES=2


# ============================================
# 【可选】Mermaid 图表校验（已改用 Node.js 校验器，本项默认无需配置）
# ============================================
# macOS:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows:
# PUPPETEER_EXECUTABLE_PATH=C:\Users\xxx\AppData\Local\Google\Chrome\Application\chrome.exe


# ============================================
# 【可选】Kafka 消息推送（如不使用可全部注释）
# ============================================
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CLIENT_ID=java-wiki
# KAFKA_TOPIC=wiki-updates
# SPACE_ID=your_space_id
