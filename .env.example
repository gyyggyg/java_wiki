# ============================================
# Java Wiki 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# Neo4j 图数据库连接（必需）
WIKI_NEO4J_URI=bolt://localhost:7689
WIKI_NEO4J_USER=neo4j
WIKI_NEO4J_PASSWORD=your_password

# LLM API 配置（必需）
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
BASE_URL=https://api.openai.com/v1

# Java 项目 pom.xml 路径（模块取名时使用）
POM_PATHS=/path/to/your/project/pom.xml

# 并发控制（可选，默认 10）
# 根据 LLM API 速率限制调整：GPT-4 Tier1 建议 10-20，Tier2 建议 50-100
MAX_CONCURRENT_BLOCKS=10

# Mermaid 图表校验用 Chrome 路径（可选，已改用 Node.js 校验）
# macOS:
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows:
# PUPPETEER_EXECUTABLE_PATH=C:\Users\xxx\AppData\Local\Google\Chrome\Application\chrome.exe

# Kafka 配置（可选，用于消息推送）
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CLIENT_ID=java-wiki
# KAFKA_TOPIC=wiki-updates
# SPACE_ID=your_space_id
